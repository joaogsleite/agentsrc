{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentsrc project manifest v1",
  "type": "object",
  "required": ["formatVersion", "targets", "modules"],
  "properties": {
    "$schema": { "type": "string" },
    "formatVersion": { "const": 1 },
    "targets": { "type": "array", "items": { "enum": ["claude", "codex", "gemini", "opencode"] } },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "revision"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "source": {
            "type": "object",
            "properties": { "local": { "type": "string" }, "github": { "type": "string", "pattern": "^[^/]+/[^/]+$" } },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
