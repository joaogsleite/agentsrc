{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentsrc module v1",
  "type": "object",
  "required": ["name", "description", "dependencies", "files"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "description": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } },
    "files": {
      "description": "Module payload paths. Files under config/ seed non-secret consumer configuration once and are never overwritten or removed.",
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
