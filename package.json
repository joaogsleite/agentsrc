{
  "name": "agentsrc",
  "version": "0.1.0",
  "description": "Generate coding-agent configuration from a canonical .agents directory.",
  "type": "module",
  "bin": "bin.mjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": ["bin.mjs", "src", "modules", "docs", "schemas"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaogsleite/agentsrc.git",
    "directory": "."
  },
  "homepage": "https://github.com/joaogsleite/agentsrc#readme",
  "bugs": "https://github.com/joaogsleite/agentsrc/issues",
  "keywords": ["agents", "claude", "codex", "gemini", "opencode", "mcp"],
  "scripts": {
    "agents": "node bin.mjs",
    "test": "vitest run",
    "test:examples": "vitest run src/integration.test.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "errore": "^0.14.1",
    "goke": "^6.8.0",
    "zod": "^4.2.0",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
