{
  "name": "agentsrc",
  "version": "0.1.0",
  "description": "Generate coding-agent configuration from a canonical .agents directory.",
  "type": "module",
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": ["src", "dist", "modules"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaogsleite/agentsrc.git",
    "directory": "."
  },
  "homepage": "https://github.com/joaogsleite/agentsrc#readme",
  "bugs": "https://github.com/joaogsleite/agentsrc/issues",
  "keywords": ["agents", "claude", "codex", "gemini", "opencode", "mcp"],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:examples": "npm run build && vitest run src/integration.test.ts",
    "check": "tsc --noEmit",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && npm run build"
  },
  "dependencies": {
    "errore": "^0.14.1",
    "goke": "^6.8.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
